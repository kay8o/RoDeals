{
  "manifest_version": 3,
  "name": "RoDeals",
  "version": "1.0.1",
  "description": "Find Roblox item deals while browsing.",

  "permissions": ["storage"],

  "action": {
    "default_popup": "popup.html",
    "default_title": "RoDeals"
  },

  "host_permissions": [
    "https://www.roblox.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://www.roblox.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
